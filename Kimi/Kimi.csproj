<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <AllowUnsafeBlocks>True</AllowUnsafeBlocks>

    <PackageId>Kimigayo</PackageId>
    <Authors>archi-Doc</Authors>
    <Product>Kimigayo</Product>
    <Description>Work in Process</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/archi-Doc/Kimigayo</PackageProjectUrl>
    <RepositoryUrl>https://github.com/archi-Doc/Kimigayo</RepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Misc\Text\strings-en.tinyhand" />
    <None Remove="Misc\Text\strings-ja.tinyhand" />
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="..\stylecop.json" Link="stylecop.json" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Misc\Text\strings-en.tinyhand" />
    <EmbeddedResource Include="Misc\Text\strings-ja.tinyhand" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Arc.Collections" Version="1.35.2" />
    <PackageReference Include="Arc.Threading" Version="0.49.1" />
    <PackageReference Include="Arc.Unit" Version="0.41.0" />
    <PackageReference Include="SimpleCommandLine" Version="0.41.2" />
    <PackageReference Include="SimplePrompt" Version="0.21.1" />
    <PackageReference Include="StyleCop.Analyzers" Version="1.2.0-beta.556">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="ValueLink" Version="0.116.0" />
  </ItemGroup>

</Project>
